{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Sources Topic Feed (JSON Feed 1.1)",
  "description": "A curated collection of URLs for a specific topic, following the JSON Feed 1.1 specification (https://jsonfeed.org/version/1.1)",
  "type": "object",
  "required": ["version", "title", "items"],
  "properties": {
    "version": {
      "type": "string",
      "const": "https://jsonfeed.org/version/1.1",
      "description": "JSON Feed version URL"
    },
    "title": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Feed title — the topic identifier in kebab-case"
    },
    "description": {
      "type": "string",
      "description": "Short description of the topic"
    },
    "language": {
      "type": "string",
      "description": "Primary language of the feed (BCP 47)"
    },
    "_tags": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Topic-level tags for discovery (extension)"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "url", "title", "_priority", "summary", "date_published", "authors"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uri",
            "description": "Unique identifier for the item (the source URL)"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Source URL"
          },
          "title": {
            "type": "string",
            "description": "Page or article title"
          },
          "summary": {
            "type": "string",
            "description": "One-line summary of the content"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Content-level tags for claim extraction"
          },
          "date_published": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when this item was added to the feed"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "url": { "type": "string", "format": "uri" }
              }
            },
            "description": "The person(s) who curated this item"
          },
          "_source_author": {
            "type": "string",
            "description": "Original author or publisher name (extension)"
          },
          "_source_date": {
            "type": "string",
            "description": "Original publication date, e.g. YYYY-MM or YYYY-MM-DD (extension)"
          },
          "_priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2"],
            "description": "Source reliability: P0=official, P1=reputable third-party, P2=community (extension)"
          },
          "_excerpt": {
            "type": "string",
            "description": "Temporary page excerpt for server-side tag generation; removed after processing (extension)"
          }
        }
      }
    }
  }
}
